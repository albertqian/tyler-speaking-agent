# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Search
SEARCH_PROVIDER=serpapi
SERPAPI_API_KEY=your-serpapi-key
MAX_RESULTS_PER_QUERY=6

# Gmail App Password
GMAIL_USER=your-sending-gmail@gmail.com

# Use the 16-character Google App Password.
# Spaces are okay if copied from Google; Gmail accepts it either way.
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

TO_EMAIL=tyler@example.com
FROM_NAME=Speaking Gig Agent

# Filtering
MIN_SCORE=5

# Local testing
DRY_RUN=true
